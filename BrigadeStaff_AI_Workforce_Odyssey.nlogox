<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[
;; =============================================================================
;; Name: Ariana Rocha (afrocha)
;; Class: Agentic Technologies
;; Assignment: Individual Assignment #1 (Coding)
;; Due Date: 22MAR2026 NLT 1159
;; GitHub: https://github.com/afrocha/AGAI_HW1_IndividualAssignment
;; NetLogo 7.x (model saved as NetLogo 7.0.3)
;; =============================================================================

;; =============================================================================
;; WORLD: Brigade Staff (Deployed) - Agent-Based Workforce + AI Integration
;; =============================================================================

breed [ soldiers soldier ]

globals [
  mission-capability
  combat-power
  avg-soldier-load
  burnout-rate
  ai-system-capability
  deployment-weeks
  initial-headcount
  automation-pressure
  training-seat-pressure
  human-loop-effect
  kill-chain-ai-direct?
  weeks-elapsed
  ;; casualty-risk-level, burnout-sensitivity, ai-shock-week? are created by Interface widgets — do not list here (NetLogo 7: duplicate global error)
]

;; =============================================================================
;; (WORKER) SOLDIER ATTRIBUTES & STATES
;; =============================================================================
soldiers-own [
  rank-str
  mos-code
  mos-long
  position-str
  resilience
  competence
  disruption-risk
  state-name
  training-kind
  training-ticks-left
  wave-num
  burnout
  workload
  casualty-reason
  shop-str
  shift-str
  grid-col              ;; 0..5 column (shop)
  grid-row              ;; 0..4 row (shift band)
]

to-report rank-pool
  report [ "SPC" "SGT" "SSG" "SFC" "MSG" "2LT" "1LT" "CPT" "MAJ" ]
end

to-report mos-rows
  report (list
    (list "11B" "Infantryman" 6)
    (list "25B" "Information Technology Specialist" 4)
    (list "35F" "Intelligence Analyst" 5)
    (list "42A" "Human Resources Specialist" 7)
    (list "92Y" "Unit Supply Specialist" 8)
    (list "36B" "Financial Management Technician" 7)
    (list "25U" "Signal Support Systems Specialist" 5)
    (list "37F" "Psychological Operations Specialist" 4)
    (list "12B" "Combat Engineer" 5)
    (list "13F" "Fire Support Specialist" 5)
    (list "19D" "Cavalry Scout" 6)
    (list "27D" "Paralegal Specialist" 6)
    (list "92A" "Automated Logistical Specialist" 7)
    (list "88M" "Motor Transport Operator" 7)
    (list "91B" "Combat Medic Specialist" 4)
    (list "17C" "Cyber Operations Specialist" 3)
    (list "35T" "Military Intelligence Systems Maintainer" 4)
    (list "25C" "Radio Operator-Maintainer" 5)
  )
end

;; One duty title per shop column (6 total; commanders/XO/CHOPs/etc. rolled into CMD)
to-report position-pool
  report [
    "S1 Personnel"
    "S2 Intelligence"
    "S3 Operations"
    "S4 Logistics"
    "S6 Signal"
    "Admin Command"
  ]
end

to-report shop-order
  report [ "S1" "S2" "S3" "S4" "S6" "CMD" ]
end

;; Unique ids per row (required for lookups); left-margin labels use human-readable shift names
to-report shift-order
  report [ "day-1" "day-2" "night-1" "night-2" "swing" ]
end

to-report shift-row-label  ;; for patch plabels on the left
  report [ "day1" "day2" "night1" "night2" "swing" ]
end

to-report grid-xcor-col [col]
  report -5 + col * 2
end

to-report row-status-label  ;; for plabels on the left
  report [ "KIA" "WIA" "OOF"]
end

to-report grid-ycor-row [row]
  report 8 - row * 2
end

;; Casualty grid (3 rows x 6 shop columns): y = -2 KIA, -4 WIA, -6 OOF (sent-home)
to-report casualty-ycor [reason]
  if reason = "KIA" [ report -2 ]
  if reason = "WIA" [ report -4 ]
  if reason = "sent-home" [ report -6 ]
  report -6
end

to-report position-disruption-mod [pos]
  if pos = "S6 Signal" [ report 1 ]
  if pos = "S2 Intelligence" [ report 1 ]
  if pos = "Admin Command" [ report 1 ]
  if pos = "S3 Operations" [ report 0 ]
  if pos = "S4 Logistics" [ report 0 ]
  if pos = "S1 Personnel" [ report 0 ]
  report 0
end

;; Fight grid: horizontal bands by shift (top to bottom). Lighter = day, darker = night, mid = swing.
;; Within each row, slight left-to-right darkening (left margin brighter).
to shade-fight-grid-by-shift
  let bases [ 9 8.5 5 4 7 ]
  foreach [0 1 2 3 4] [ row ->
    let yrow grid-ycor-row row
    let b item row bases
    foreach (list -5 -3 -1 1 3 5) [ xc ->
      let across ((xc + 5) / 2)
      ask patch xc yrow [
        set pcolor (b - (across * 0.12))
      ]
    ]
  ]
end

;; Black 3x6 under fight grid; left margin labels at pxcor -12 (clear of shift labels at -10)
to paint-casualty-zone
  ask patches with [
    member? pxcor [-5 -3 -1 1 3 5] and member? pycor [-2 -4 -6]
  ] [
    set pcolor black
  ]
end

;; Shop names on pycor 11 (above the grid); shift names on pxcor -10 (left of grid)... never overlap agents
to draw-formation-headers
  ask patches [ set plabel "" ]
  let header-pycor 11
  let header-pxcor -10
  foreach (shop-order) [ sh ->
    let col position sh (shop-order)
    if col != false [
      ask patch (grid-xcor-col col) header-pycor [
        set plabel sh
        set plabel-color black
      ]
    ]
  ]
  foreach [0 1 2 3 4] [ r ->
    let lab item r (shift-row-label)
    ask patch header-pxcor (grid-ycor-row r) [
      set plabel lab
      set plabel-color black
    ]
  ]
  let margin-px -10
  foreach [0 1 2] [ i ->
    let lab item i (row-status-label)
    let ypatch item i [-2 -4 -6]
    ask patch margin-px ypatch [
      set plabel lab
      set plabel-color black
    ]
  ]
  ask patch header-pxcor header-pycor [ set plabel "" ]
end

;;to update-agent-label
  ;;;; Shop + shift from formation grid; casualty row + shop column from black grid with no turtle text on top
  ;;set label ""
  ;;set label-color black
;;end

to update-agent-label
  set label rank-str
  ifelse state-name = "unemployed"
    [ set label-color black ]   ;; readable on black casualty rows
    [ set label-color black ]
end

to layout-formation
  ask soldiers with [ state-name != "unemployed" ] [
    set xcor grid-xcor-col grid-col
    set ycor grid-ycor-row grid-row
  ]
  ;; Per casualty type: fill left to right across the 6 shop columns; wrap with horizontal nudge
  foreach ["KIA" "WIA" "sent-home"] [ rs ->
    let grp sort-on [who] soldiers with [ state-name = "unemployed" and casualty-reason = rs ]
    let k 0
    foreach grp [ t ->
      ask t [
        let col (k mod 6)
        let layer floor (k / 6)
        set xcor (grid-xcor-col col) + (layer * 0.24)
        set ycor casualty-ycor rs
      ]
      set k k + 1
    ]
  ]
  ask soldiers [ update-agent-label ]
end

;; =============================================================================
;; SCENARIOS
;; =============================================================================

to apply-scenario-presets
  ifelse scenario = "tech-driven" [
    set automation-pressure 0.85
    set training-seat-pressure 1.35
    set human-loop-effect 0.55
    set kill-chain-ai-direct? true
    set ai-system-capability 62
  ] [
    set automation-pressure 0.55
    set training-seat-pressure 0.85
    set human-loop-effect 0.90
    set kill-chain-ai-direct? false
    set ai-system-capability 48
  ]
end

to startup
  set scenario "tech-driven"
end

;;to setup
  ;;let _scenario scenario
  ;;if (_scenario != "tech-driven" and _scenario != "human-centric") [ set _scenario "tech-driven" ]
  ;;clear-all
  ;;set scenario _scenario
  ;;random-seed new-seed

to setup
  let _scenario scenario
  if (_scenario != "tech-driven" and _scenario != "human-centric") [ set _scenario "tech-driven" ]
  let _casualty casualty-risk-level
  let _burnout burnout-sensitivity
  let _shock ai-shock-week?
  clear-all
  set scenario _scenario
  set casualty-risk-level _casualty
  set burnout-sensitivity _burnout
  set ai-shock-week? _shock
  if casualty-risk-level <= 0 [ set casualty-risk-level 100 ]
  if burnout-sensitivity <= 0 [ set burnout-sensitivity 100 ]
  random-seed new-seed

  set deployment-weeks 36
  set-default-shape soldiers "person"
  apply-scenario-presets

  ask patches [ set pcolor white ]
  shade-fight-grid-by-shift

  set initial-headcount 30
  create-soldiers initial-headcount [
    set size 1.55
    set grid-col (who mod 6)
    set grid-row floor (who / 6)
    set shop-str item grid-col shop-order
    set shift-str item grid-row shift-order
    set position-str item grid-col position-pool
    set color green
    assign-random-traits
    set burnout 5 + random 15
    set workload 20 + random 20
    set casualty-reason ""
    set training-kind "none"
    set training-ticks-left 0
  ]

  ask soldiers [
    set wave-num (who mod 4) + 1
    set state-name "in-training"
    set training-kind "initial-month"
    set training-ticks-left (5 - wave-num)
    set color yellow
  ]

  draw-formation-headers
  paint-casualty-zone
  layout-formation

  compute-system-metrics
  reset-ticks
  set weeks-elapsed 0
  print (word "Setup done. 30 pax | 5x6 grid | scenario: " scenario)
end

to use-tech-driven
  set scenario "tech-driven"
  setup
end

to use-human-centric
  set scenario "human-centric"
  setup
end

to assign-random-traits
  ifelse grid-col = 5 [
    set rank-str one-of [ "CPT" "MAJ" ]
  ] [
    set rank-str one-of [ "SPC" "SGT" "SSG" "SFC" "MSG" "2LT" "1LT" ]
  ]
  let row one-of mos-rows
  set mos-code first row
  set mos-long item 1 row
  let routine item 2 row
  set resilience 3 + random 8
  set competence 3 + random 8
  let pmod position-disruption-mod position-str
  set disruption-risk min (list 10 (max (list 1 (routine + pmod + random 3 - 1))))
end

;; =============================================================================
;; TRANSITIONS
;; =============================================================================

to go
  if not any? soldiers [
    print "Run setup first: click setup or type setup in the Command Center, then go."
    stop
  ]
  if weeks-elapsed >= deployment-weeks [ stop ]

  ask soldiers [
    if state-name = "in-training" and training-ticks-left > 0 [
      set training-ticks-left training-ticks-left - 1
    ]
  ]
  ask soldiers with [ state-name = "in-training" and training-ticks-left = 0 ] [
    ifelse training-kind = "initial-month" [
      set state-name "employed"
      set training-kind "none"
      set color green
    ] [
      ifelse training-kind = "ai-week" [
        set state-name "re-employed"
        set training-kind "none"
        set color cyan
      ] [
        set state-name "employed"
        set training-kind "none"
        set color green
      ]
    ]
  ]

  ask soldiers with [ member? state-name ["employed" "re-employed"] and grid-col != 5 ] [
    ;;let p (automation-pressure * (disruption-risk / 10) * (1.1 - (human-loop-effect * 0.5)))
    let shock-m ifelse-value ai-shock-week? [ 1.35 ] [ 1.0 ]
    let p (automation-pressure * (disruption-risk / 10) * (1.1 - (human-loop-effect * 0.5)) * shock-m)
    set p min (list 0.45 (max (list 0.0 p)))
    if random-float 1.0 < p [
      set state-name "at-risk"
      set color orange
    ]
  ]

  ask soldiers with [ state-name = "at-risk" and grid-col != 5 ] [
    let base 0.55 / training-seat-pressure
    set base min (list 0.85 (max (list 0.05 base)))
    if random-float 1.0 < base [
      set state-name "in-training"
      set training-kind "ai-week"
      set training-ticks-left 1
      set color yellow
    ]
  ]

  ;;let contact-rate 0.005 + random-float 0.005
  ;;let shock-c ifelse-value ai-shock-week? [ 1.75 ] [ 1.0 ]
  let contact-rate min (list 0.95 ((0.02 + random-float 0.02) * (casualty-risk-level / 100)))
  ;;let contact-rate min (list 0.95 ((0.005 + random-float 0.005) * (casualty-risk-level / 100)))
  ask soldiers with [ member? state-name ["employed" "at-risk" "in-training" "re-employed"] ] [
    if random-float 1.0 < contact-rate [
      set state-name "unemployed"
      set training-kind "none"
      set training-ticks-left 0
      let r random 3
      ifelse r = 0 [ set casualty-reason "WIA" ] [
        ifelse r = 1 [ set casualty-reason "KIA" ] [ set casualty-reason "sent-home" ]
      ]
      set color red
    ]
  ]

  redistribute-load-and-burnout

  ifelse scenario = "tech-driven" [
    set ai-system-capability min (list 95 (ai-system-capability + 0.35))
  ] [
    set ai-system-capability min (list 85 (ai-system-capability + 0.18))
  ]

  compute-system-metrics
  layout-formation
  tick
  set weeks-elapsed weeks-elapsed + 1
end

to redistribute-load-and-burnout
  let in-train count soldiers with [ state-name = "in-training" ]
  let fighters count soldiers with [ member? state-name ["employed" "at-risk" "in-training" "re-employed"] ]
  let redistribution 0
  if fighters > 0 [
    let r (in-train / fighters) * 38
    ifelse kill-chain-ai-direct? [
      set redistribution r * 1.25
    ] [
      set redistribution r * 0.85
    ]
  ]
  let bs (burnout-sensitivity / 100)
  ask soldiers with [ member? state-name ["employed" "at-risk" "re-employed"] ] [
    let base 18 + (10 - competence) * 0.8
    set workload base + redistribution
    let damp (resilience / 10)
    ;;set burnout min (list 100 (burnout + (workload * 0.06 * (2.0 - damp)) - 0.15))
    ;;let bs (burnout-sensitivity / 100)
    set burnout min (list 100 (burnout + bs * ((workload * 0.06 * (2.0 - damp)) - 0.15)))
  ]
  ask soldiers with [ state-name = "in-training" ] [
    let base 26
    set workload base
    let damp (resilience / 10)
    ;;set burnout min (list 100 (burnout + (workload * 0.16 * (2.0 - damp)) - 0.25))
    ;;let bs (burnout-sensitivity / 100)
    set burnout min (list 100 (burnout + bs * ((workload * 0.16 * (2.0 - damp)) - 0.25)))
  ]
end

;; =============================================================================
;; OUTPUTS
;; =============================================================================
to compute-system-metrics
  let head max (list 1 initial-headcount)

  let n-emp   count soldiers with [ state-name = "employed" ]
  let n-re    count soldiers with [ state-name = "re-employed" ]
  let n-tr    count soldiers with [ state-name = "in-training" ]
  let n-risk  count soldiers with [ state-name = "at-risk" ]
  let n-cas   count soldiers with [ state-name = "unemployed" ]

  let survivors soldiers with [ state-name != "unemployed" ]
  let n-surv count survivors

  ifelse any? survivors [
    let br mean [ burnout ] of survivors
    set burnout-rate br
    let base-load mean [ workload ] of survivors
    ;; fewer survivors => more carried per living person (cap so the series stays plausible)
    let carry-factor min (list 2.4 (head / max (list 1 n-surv)))
    let wk max (list 0 weeks-elapsed)
    let span max (list 1 deployment-weeks)
    let load-drift min (list 1.28 (1 + (wk / span) * 0.25))
    ;; tighter coupling to burnout so load “mirrors” burnout more on the plot
    set avg-soldier-load base-load * carry-factor * (1 + (br / 100) * 0.45) * load-drift
  ] [
    set avg-soldier-load 0
    set burnout-rate 0
  ]

  let cas-rate (n-cas / head)
  let br-mean ifelse-value (any? survivors) [ mean [ burnout ] of survivors ] [ 0 ]

  ;; --- mission capability (25–100 %): higher baseline, softer drags, wider jitter ---
  let trained-mass-pct ((n-emp + n-re * 1.18) / head) * 100
  let train-mass-pct   ((n-tr / head) * 100)
  let risk-drag        ((n-risk / head) * 100) * 0.16
  let cas-drag         cas-rate * 100 * 0.30
  let burn-drag        (br-mean / 100) * 16
  let ai-boost         (ai-system-capability / 100) * 38

  let rng-success      (random-float 12 - 6)
  let rng-enemy        (random-float 10 - 5)
  let rng-ops          (random-float 6 - 3)

  let human-adj ifelse-value (scenario = "human-centric") [ 10 ] [ -3 ]

  set mission-capability trained-mass-pct * 0.50 + train-mass-pct * 0.24
    - risk-drag - cas-drag - burn-drag + ai-boost + human-adj
    + rng-success - rng-enemy + rng-ops + 10

  set mission-capability max (list 10 (min (list 100 mission-capability)))

  ;; --- combat power (25–100) ---
  let line-pct ((n-emp + n-re + n-tr * 0.9 + n-risk * 0.55) / head) * 100
  let cas-smash cas-rate * 100 * 0.62
  let ai-nudge (ai-system-capability / 100) * 9
  let human-c ifelse-value (scenario = "human-centric") [ 10 ] [ -5 ]

  set combat-power line-pct - cas-smash + ai-nudge + human-c
  set combat-power max (list 10 (min (list 100 combat-power)))
end]]></code>
