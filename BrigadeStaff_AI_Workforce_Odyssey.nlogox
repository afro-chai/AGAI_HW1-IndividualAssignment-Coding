    <view x="10" wrappingAllowedX="true" y="14" frameRate="30.0" minPycor="-12" height="409" showTickCounter="true" patchSize="17.8" fontSize="12" wrappingAllowedY="true" width="409" tickCounterLabel="week" maxPycor="12" updateMode="0" maxPxcor="12" minPxcor="-12"></view>
    <button x="20" y="435" height="44" disableUntilTicks="false" forever="false" kind="Observer" display="setup" width="110" sizeVersion="0">setup</button>
    <button x="140" y="435" height="44" disableUntilTicks="false" forever="true" kind="Observer" display="go" width="110" sizeVersion="0">go</button>
    <plot x="715" autoPlotX="true" yMax="100.0" autoPlotY="true" yAxis="Percent" y="15" xMin="0.0" height="215" legend="true" xMax="36.0" yMin="0.0" width="360" xAxis="Deployment Week" display="Mission Capabiliy &amp; Combat Power Over Deployment Period">
