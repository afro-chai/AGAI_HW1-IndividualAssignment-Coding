      </pen>
    </plot>
    <slider x="435" step="1" y="150" max="100" width="265" display="burnout-sensitivity" height="50" min="25" direction="Horizontal" default="75.0" variable="burnout-sensitivity"></slider>
    <chooser x="435" y="15" height="55" variable="Scenario" current="1" display="Scenario" width="265" sizeVersion="0">
      <choice type="string" value="tech-driven"></choice>
      <choice type="string" value="human-centric"></choice>
    </chooser>
    <slider x="435" step="1" y="85" max="100" width="265" display="casualty-risk-level" height="50" min="0" direction="Horizontal" default="50.0" variable="casualty-risk-level"></slider>
    <switch x="505" y="210" height="40" on="false" variable="ai-shock-week?" width="125" display="ai-shock-week?"></switch>
    <note x="435" y="265" backgroundDark="-1" fontSize="11" width="265" markdown="false" height="155" textColorDark="-16777216" textColorLight="-16777216" backgroundLight="-657931">MODEL ORIENTATION:
Thirty soldier formation on a 5×6 grid (shifts × shops); color = state (yellow training, green employed, orange at-risk, cyan re-employed, red casualty / unemployed). The black rows label losses KIA / WIA / OOF. Use Scenario for tech-driven vs human-centric, casualty risk and burnout sensitivity to tune stress, then setup and go; the plots track capability, combat power, workload, and burnout over the deployment.</note>
    <plot x="715" autoPlotX="true" yMax="100.0" autoPlotY="true" yAxis="Percent" y="240" xMin="0.0" height="180" legend="true" xMax="36.0" yMin="0.0" width="360" xAxis="Deployment Week" display="Average Soldier Load &amp; Burnout">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Average Load" color="-16777216" legend="true">
        <setup></setup>
        <update>plot avg-soldier-load</update>
      </pen>
      <pen interval="1.0" mode="0" display="Burnout" color="-2674135" legend="true">
        <setup></setup>
        <update>plot burnout-rate</update>
      </pen>
    </plot>
  </widgets>
